<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:TombLauncher.Localization">
    <!-- Xian Theme: Rust & Emerald -->
    <!-- Primary Backgrounds -->
    <Color x:Key="CardBackgroundColor">#CC261A1A</Color>
    <SolidColorBrush x:Key="CARDBACKGROUNDBRUSH" Color="{StaticResource CardBackgroundColor}" /> <!-- Glassy Dark Rust -->
    <SolidColorBrush x:Key="CARDBORDERBRUSH">#33FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="PAGEBACKGROUNDBRUSH">#150F0F</SolidColorBrush>
    <SolidColorBrush x:Key="SIDEBARBACKGROUNDBRUSH">#0F0B0B</SolidColorBrush>
    
    <!-- Primary Actions -->
    <Color x:Key="PRIMARYCOLOR">#B7410E</Color>
    <SolidColorBrush x:Key="PRIMARYBRUSH" Color="{StaticResource PrimaryColor}" /> <!-- Rust -->
    <SolidColorBrush x:Key="PRIMARYPOINTEROVERBRUSH">#D05015</SolidColorBrush>
    <SolidColorBrush x:Key="COLOREDBUTTONTEXTBRUSH">#FFFFFF</SolidColorBrush>

    <!-- Accents -->
    <SolidColorBrush x:Key="ACCENTBRUSH">#50C878</SolidColorBrush> <!-- Emerald -->
    
    <!-- Status -->
    <SolidColorBrush x:Key="SUCCESSBRUSH">#50C878</SolidColorBrush> <!-- Emerald -->
    <SolidColorBrush x:Key="SUCCESSPOINTEROVERBRUSH">#157347</SolidColorBrush>
    <SolidColorBrush x:Key="DANGERBRUSH">#dc3545</SolidColorBrush>
    <SolidColorBrush x:Key="DANGERPOINTEROVERBRUSH">#b02a37</SolidColorBrush>
    <SolidColorBrush x:Key="WARNINGBRUSH">#ffc107</SolidColorBrush>
    <SolidColorBrush x:Key="WarningPointerOverBrush">#ffcd39</SolidColorBrush>
    
    <!-- Text -->
    <SolidColorBrush x:Key="TEXTBRUSH">#E0E0E0</SolidColorBrush>
    <SolidColorBrush x:Key="MUTEDTEXTBRUSH">#A0A0A0</SolidColorBrush>
    <SolidColorBrush x:Key="SECONDARYBRUSH">#A0A0A0</SolidColorBrush>
</ResourceDictionary>
