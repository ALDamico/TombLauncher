<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:TombLauncher.Localization">
    <!-- Scion Theme: Deep Teal & Gold -->
    <!-- Primary Backgrounds -->
    <Color x:Key="CardBackgroundColor">#CC1A2626</Color>
    <SolidColorBrush x:Key="CARDBACKGROUNDBRUSH" Color="{StaticResource CardBackgroundColor}" /> <!-- Glassy Dark Teal -->
    <SolidColorBrush x:Key="CARDBORDERBRUSH">#33FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="PAGEBACKGROUNDBRUSH">#0F1515</SolidColorBrush>
    <!-- Fluent Theme Overrides -->
    <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="MENUFLYOUTPRESENTERBACKGROUND" Color="{StaticResource CardBackgroundColor}" />
    
    <Color x:Key="CardBorderColor">#33FFFFFF</Color>
    <SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush" Color="{StaticResource CardBorderColor}" />
    <!-- Primary Actions -->
    <Color x:Key="PRIMARYCOLOR">#008080</Color>
    <SolidColorBrush x:Key="PRIMARYBRUSH" Color="{StaticResource PrimaryColor}" /> <!-- Teal -->
    <SolidColorBrush x:Key="PRIMARYPOINTEROVERBRUSH">#009999</SolidColorBrush>
    <SolidColorBrush x:Key="COLOREDBUTTONTEXTBRUSH">#FFFFFF</SolidColorBrush>

    <!-- Accents -->
    <SolidColorBrush x:Key="ACCENTBRUSH">#FFD700</SolidColorBrush> <!-- Gold -->
    
    <!-- Status -->
    <SolidColorBrush x:Key="SUCCESSBRUSH">#198754</SolidColorBrush>
    <SolidColorBrush x:Key="SUCCESSPOINTEROVERBRUSH">#157347</SolidColorBrush>
    <SolidColorBrush x:Key="DANGERBRUSH">#dc3545</SolidColorBrush>
    <SolidColorBrush x:Key="DANGERPOINTEROVERBRUSH">#b02a37</SolidColorBrush>
    <SolidColorBrush x:Key="WARNINGBRUSH">#ffc107</SolidColorBrush>
    <SolidColorBrush x:Key="WarningPointerOverBrush">#ffcd39</SolidColorBrush>
    
    <!-- Text -->
    <SolidColorBrush x:Key="TEXTBRUSH">#E0E0E0</SolidColorBrush>
    <SolidColorBrush x:Key="MUTEDTEXTBRUSH">#A0A0A0</SolidColorBrush>
    <SolidColorBrush x:Key="SECONDARYBRUSH">#A0A0A0</SolidColorBrush>
</ResourceDictionary>
