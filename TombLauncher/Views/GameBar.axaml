<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:TombLauncher.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:TombLauncher.ViewModels.Pages"
             xmlns:controls="clr-namespace:TombLauncher.Controls;assembly=TombLauncher.Controls"
             xmlns:viewModels="clr-namespace:TombLauncher.ViewModels"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             xmlns:io="clr-namespace:System.IO;assembly=System.Runtime"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="pages:GameDetailsViewModel"
             x:Class="TombLauncher.Views.GameBar"
             x:Name="ViewRoot">
    <Design.DataContext>
        <pages:GameDetailsViewModel />
    </Design.DataContext>
    <Border CornerRadius="5" MaxHeight="100" Classes="card-background">
        <DockPanel LastChildFill="True">
            <controls:IconButton Height="65"
                                 DockPanel.Dock="Right"
                                 Margin="5 5 10 5"
                                 Padding="0 5"
                                 FontSize="28"
                                 Icon="DotsHorizontal"
                                 IsTextVisible="False"
                                 CornerRadius="50">
                <controls:IconButton.Flyout>
                    <MenuFlyout>
                        <MenuItem Header="{loc:Translate LAUNCH_OPTIONS}" 
                                  Command="{Binding OpenLaunchOptionsCmd}"
                                  ToolTip.Tip="{loc:Translate LAUNCH_OPTIONS_TOOLTIP}">
                            <MenuItem.Icon>
                                <avalonia:MaterialIcon Kind="Terminal"></avalonia:MaterialIcon>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Savegames}" 
                                  Command="{Binding ManageSaveGamesCmd}"
                                  IsVisible="{Binding Game.GameMetadata.InstallDirectory, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <MenuItem.Icon>
                                <avalonia:MaterialIcon Kind="Floppy"></avalonia:MaterialIcon>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Browse files}" 
                                  IsVisible="{Binding Game.GameMetadata.InstallDirectory, Converter={x:Static ObjectConverters.IsNotNull}}"
                                  Command="{Binding BrowseFolderCmd}">
                            <MenuItem.Icon>
                                <avalonia:MaterialIcon Kind="FolderOpen"></avalonia:MaterialIcon>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem ItemsSource="{Binding WalkthroughLinks}" 
                                  Header="{loc:Translate READ_WALKTHROUGH}" IsEnabled="{Binding WalkthroughLinks, Converter={StaticResource CollectionNotEmptyToVisibilityConverter}}">
                            <MenuItem.ItemContainerTheme>
                                <ControlTheme TargetType="MenuItem"
                                              BasedOn="{StaticResource {x:Type MenuItem}}"
                                              x:DataType="viewModels:GameLinkViewModel">
                                    <Setter Property="Header"
                                            Value="{Binding DisplayName, Converter={StaticResource LocalizedStringConverter}, ConverterParameter='From SITENAME'}">
                                    </Setter>
                                    <Setter Property="Command"
                                            Value="{Binding ElementName=ViewRoot, Path=((pages:GameDetailsViewModel)DataContext).ReadWalkthroughCmd}" />
                                    <Setter Property="CommandParameter" Value="{Binding .}"></Setter>
                                    
                                    <!-- Visual Overrides for Dynamic Items -->
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                    <Setter Property="CornerRadius" Value="4" />
                                </ControlTheme>
                            </MenuItem.ItemContainerTheme>
                            <MenuItem.Icon>
                                <avalonia:MaterialIcon Kind="Map"></avalonia:MaterialIcon>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{loc:Translate DOCUMENTATION}" ItemsSource="{Binding DocumentationFiles}" 
                                  IsEnabled="{Binding DocumentationFiles, Converter={StaticResource CollectionNotEmptyToVisibilityConverter}}">
                            <MenuItem.ItemContainerTheme>
                                <ControlTheme TargetType="MenuItem"
                                              BasedOn="{StaticResource {x:Type MenuItem}}"
                                              x:DataType="io:FileInfo">
                                    <Setter Property="Header" Value="{Binding Name}"></Setter>
                                    <Setter Property="Command" 
                                            Value="{Binding ElementName=ViewRoot, Path=((pages:GameDetailsViewModel)DataContext).OpenDocumentCommand}"></Setter>
                                    <Setter Property="CommandParameter" Value="{Binding FullName}"></Setter>
                                    
                                    <!-- Visual Overrides for Dynamic Items -->
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                    <Setter Property="CornerRadius" Value="4" />
                                </ControlTheme>
                            </MenuItem.ItemContainerTheme>
                        </MenuItem>
                    </MenuFlyout>
                </controls:IconButton.Flyout>
            </controls:IconButton>

            <StackPanel Orientation="Horizontal">
                <controls:IconButton Height="65"
                                     Margin="0 5 10 5"
                                     Padding="0 5"
                                     FontSize="28"
                                     IsVisible="{Binding Game.GameMetadata.InstallDirectory, Converter={x:Static ObjectConverters.IsNull}}"
                                     Command="{Binding InstallCmd}"
                                     Icon="Download"
                                     Text="{loc:Translate DOWNLOAD}"
                                     Classes="btn-success" />
                <controls:IconButton
                    Height="65"
                    FontSize="28"
                    IsVisible="{Binding Game.GameMetadata.IsInstalled, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Classes="btn-success"
                    Icon="Play"
                    Text="{loc:Translate PLAY}"
                    Margin="10 5"
                    Padding="0 5"
                    Command="{Binding Game.PlayCmd}">
                    <controls:SplitIconButton.Flyout>
                    </controls:SplitIconButton.Flyout>
                </controls:IconButton>
                <controls:IconButton Icon="Gear" ToolTip.Tip="{loc:Translate CONFIGURE}" Classes="btn-primary"
                                     FontSize="28" Height="65"
                                     IsTextVisible="False"
                                     IsVisible="{Binding SetupCommands, Converter={StaticResource CollectionNotEmptyToVisibilityConverter}}">
                    <Button.Flyout>
                        <MenuFlyout ItemsSource="{Binding SetupCommands}">
                            <MenuFlyout.ItemContainerTheme>
                                <ControlTheme TargetType="MenuItem"
                                              BasedOn="{StaticResource {x:Type MenuItem}}"
                                              x:DataType="viewModels:CommandViewModel">
                                    <Setter Property="Command" Value="{Binding Command}" />
                                    
                                    <!-- Visual Overrides for Dynamic Items -->
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                    <Setter Property="CornerRadius" Value="4" />
                                </ControlTheme>
                            </MenuFlyout.ItemContainerTheme>
                            <MenuFlyout.ItemTemplate>
                                <DataTemplate DataType="viewModels:CommandViewModel">
                                    <MenuItem Header="{Binding Text}"
                                              Command="{Binding Command}">
                                        <MenuItem.Icon>
                                            <avalonia:MaterialIcon Kind="{Binding Icon}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </DataTemplate>
                            </MenuFlyout.ItemTemplate>
                        </MenuFlyout>
                    </Button.Flyout>
                </controls:IconButton>
                <avalonia:MaterialIcon Kind="Trophy"
                                       Height="28"
                                       Width="28"
                                       IsVisible="{Binding Game.GameMetadata.IsCompleted}"
                                       ToolTip.Tip="{StaticResource 'Game completed'}" />
                <avalonia:MaterialIcon Kind="Heart"
                                       Height="28"
                                       Width="28"
                                       IsVisible="{Binding Game.GameMetadata.IsFavourite}"
                                       ToolTip.Tip="{StaticResource 'Favourite'}" />
                <TextBlock Text="{StaticResource 'Last played'}"
                           FontStyle="Italic"
                           Margin="0 5 10 5"
                           VerticalAlignment="Center"
                           IsVisible="{Binding Game.LastPlayed, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <TextBlock Margin="0 5 10 5"
                           VerticalAlignment="Center"
                           Text="{Binding Game.LastPlayed, StringFormat=g}"
                           IsVisible="{Binding Game.LastPlayed, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <TextBlock Text="{StaticResource 'Play time'}"
                           FontStyle="Italic"
                           Margin="0 5 10 5"
                           VerticalAlignment="Center"
                           IsVisible="{Binding Game.LastPlayed, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <TextBlock Margin="0 5 10 5"
                           VerticalAlignment="Center"
                           Text="{Binding Game.TotalPlayedTime, Converter={StaticResource TimeSpanToHumanReadableStringConverter}}"
                           IsVisible="{Binding Game.TotalPlayedTime, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter={x:Static system:TimeSpan.Zero}}" />

            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>