<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:TombLauncher.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:TombLauncher.ViewModels"
             xmlns:controls="clr-namespace:TombLauncher.Controls;assembly=TombLauncher.Controls"
             xmlns:converters="clr-namespace:TombLauncher.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TombLauncher.Views.NotificationView"
             x:DataType="viewModels:NotificationViewModel">
    <Design.DataContext>
        <viewModels:NotificationViewModel />
    </Design.DataContext>
    <UserControl.Resources>
        <converters:NotificationTypeToColorConverter x:Key="NotificationTypeToColorConverter"/>
    </UserControl.Resources>
    
    <UserControl.Styles>
        <!-- Wrapper Styles: Handle Entrance and Exit Animations (Translation/Opacity) -->
        <Style Selector="Grid.notification-wrapper">
             <!-- Removed RenderTransform setter to avoid conflict with TranslateTransform.X animation -->
            <Style.Animations>
                <Animation Duration="0:0:0.4" Easing="CubicEaseOut"> 
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.0"/>
                        <Setter Property="TranslateTransform.X" Value="20"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0"/>
                        <Setter Property="TranslateTransform.X" Value="0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        
        <Style Selector="Grid.notification-wrapper.closing">
            <Style.Animations>
                <Animation Duration="0:0:0.3" Easing="CubicEaseIn" FillMode="Forward"> 
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.0"/>
                        <Setter Property="TranslateTransform.X" Value="100"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Card Styles: Handle Hover Effects (Scale/Shadow) -->
        <Style Selector="Border.notification-card">
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Grid.notification-wrapper:pointerover > Border.notification-card">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
            <Setter Property="BoxShadow" Value="0 8 16 0 #60000000"/>
        </Style>
    </UserControl.Styles>
    
    <Grid Classes="notification-wrapper" Classes.closing="{Binding IsClosing}" Margin="5,5,5,5" Background="Transparent">
        <Grid.RenderTransform>
            <TranslateTransform />
        </Grid.RenderTransform>
        <Border Background="{loc:Translate CARDBACKGROUND}" 
                CornerRadius="8" 
                Classes="notification-card"
                BoxShadow="0 4 8 0 #40000000">
            <Grid>
                <!-- Left Colored Strip -->
                <Border HorizontalAlignment="Left" 
                        Width="6" 
                        CornerRadius="8,0,0,8"
                        Background="{Binding Type, Converter={StaticResource NotificationTypeToColorConverter}}"/>
                
                <Grid Margin="16, 8, 8, 8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Title and Timestamp -->
                    <DockPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top" FontSize="11" Opacity="0.7" 
                                   Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"/>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" TextWrapping="Wrap" />
                    </DockPanel>
    
                    <!-- Actions (Buttons) -->
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" VerticalAlignment="Top" Spacing="4">
                        <controls:RoundIconButton Icon="{Binding OpenIcon}" Command="{Binding OpenCommand}"
                                             CommandParameter="{Binding OpenCmdParam}"
                                             IsVisible="{Binding IsOpenable}" Classes="btn-success"
                                             ToolTip.Tip="Open"/>
                        
                        <controls:RoundIconButton Icon="Cancel" Command="{Binding CancelCommand}" 
                                                  IsVisible="{Binding IsCancelable}"
                                                  Classes="btn-danger"
                                                  ToolTip.Tip="Cancel"/>
                        
                        <controls:RoundIconButton Icon="Close" Command="{Binding DismissCmd}"
                                                  CommandParameter="{Binding .}"
                                                  IsVisible="{Binding IsDismissable}"
                                                  Classes="round-button" 
                                                  ToolTip.Tip="Dismiss"/>
                    </StackPanel>
    
                    <!-- Content -->
                    <ContentControl Grid.Row="1" Grid.Column="0" Content="{Binding Content}" Margin="0,5,0,0"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>