<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:TombLauncher.ViewModels.Pages.Settings"
             xmlns:loc="clr-namespace:TombLauncher.Localization;assembly=TombLauncher.Localization"
             xmlns:controls="clr-namespace:TombLauncher.Controls;assembly=TombLauncher.Controls"
             xmlns:ai="clr-namespace:TombLauncher.Views.Ai"
             xmlns:svg="clr-namespace:Avalonia.Svg;assembly=Svg.Controls.Avalonia"
             xmlns:enums="clr-namespace:TombLauncher.Contracts.Enums;assembly=TombLauncher.Contracts"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TombLauncher.Views.AiSettingsView"
             x:DataType="settings:AiSettingsViewModel">
    <StackPanel Orientation="Vertical" Spacing="8">
        <TextBlock Text="{loc:Translate IS_ENABLED}"></TextBlock>
        <ToggleSwitch IsChecked="{Binding IsEnabled}"></ToggleSwitch>
        <DockPanel LastChildFill="True">
            <controls:Infotip DockPanel.Dock="Right" Header="{loc:Translate LLM_BACKEND}" ToolTipContent="{loc:Translate LLM_BACKEND_HELP}" />
            <TextBlock Text="{loc:Translate LLM_BACKEND}"></TextBlock>
        </DockPanel>
        <ComboBox ItemsSource="{Binding AvailableBackendTypes}" SelectedItem="{Binding SelectedBackendType}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="26" Height="26" Background="White">
                            <svg:Svg HorizontalAlignment="Center" VerticalAlignment="Center" Width="24" Height="24"
                                     Path="{Binding ., Converter={StaticResource AiBackendTypeToIconConverter}}" />
                        </Border>
                        <TextBlock Margin="4, 0, 0, 0"
                                   Text="{Binding ., Converter={StaticResource EnumToDescriptionConverter}}" />
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="{loc:Translate AI_BACKEND_ENDPOINT}" />
        <DockPanel LastChildFill="True">
            <Ellipse DockPanel.Dock="Right" Width="12" Height="12" Margin="8, 0"
                     ToolTip.Tip="{Binding CheckResultMessage}"
                     Classes.checking="{Binding AiBackendCheckStatus, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static enums:ServiceCheckStatus.Checking}}"
                     Fill="{Binding AiBackendCheckStatus, Converter={StaticResource ServiceCheckStatusToColorConverter}}">
                <Ellipse.Styles>
                    <Style Selector="Ellipse.checking">
                        <Style.Animations>
                            <Animation Duration="0:0:0.8" IterationCount="INFINITE" Easing="SineEaseInOut">
                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                                <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.15" /></KeyFrame>
                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </Ellipse.Styles>
            </Ellipse>
            <TextBox Text="{Binding Endpoint}" />
        </DockPanel>
        
        <TextBlock Text="{loc:Translate AI_BACKEND_API_KEY}" />
        <TextBox Text="{Binding ApiKey}"></TextBox>
        <TextBlock Text="{loc:Translate EMBEDDING_MODEL}"></TextBlock>
        <DockPanel LastChildFill="True">
            <Ellipse DockPanel.Dock="Right" Width="12" Height="12" Margin="8, 0"
                     ToolTip.Tip="{Binding EmbeddingModelCheckResultMessage}"
                     Classes.checking="{Binding EmbeddingModelCheckStatus, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static enums:ServiceCheckStatus.Checking}}"
                     Fill="{Binding EmbeddingModelCheckStatus, Converter={StaticResource ServiceCheckStatusToColorConverter}}">
                <Ellipse.Styles>
                    <Style Selector="Ellipse.checking">
                        <Style.Animations>
                            <Animation Duration="0:0:0.8" IterationCount="INFINITE" Easing="SineEaseInOut">
                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                                <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.15" /></KeyFrame>
                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </Ellipse.Styles>
            </Ellipse>
            <TextBlock Text="{Binding EmbeddingModelId}"></TextBlock>
        </DockPanel>
        
        
        
        <DockPanel LastChildFill="True">
            <controls:Infotip DockPanel.Dock="Right"
                              Header="{loc:Translate LLM_MODEL}"
                              ToolTipContent="{loc:Translate LLM_MODEL_DESCRIPTION}" />
            <TextBlock Text="{loc:Translate LLM_MODEL}"></TextBlock>
        </DockPanel>
        <ItemsControl ItemsSource="{Binding AvailableModels}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ai:AiModelCard />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>