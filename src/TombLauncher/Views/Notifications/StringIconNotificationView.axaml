<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             xmlns:notifications="clr-namespace:TombLauncher.ViewModels.Notifications"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TombLauncher.Views.Notifications.StringIconNotificationView"
             x:DataType="notifications:StringIconNotificationViewModel">
    <Design.DataContext>
        <notifications:StringIconNotificationViewModel/>
    </Design.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <iconPacks:PackIconRemixIcon Grid.Column="0" Kind="{Binding Icon}" Classes="warning" Width="24" Height="24" VerticalAlignment="Top"/>
        <TextBlock Grid.Column="1" Margin="10, 0, 0, 0" Text="{Binding Text}" TextWrapping="Wrap" VerticalAlignment="Top"/>    
    </Grid>
</UserControl>
