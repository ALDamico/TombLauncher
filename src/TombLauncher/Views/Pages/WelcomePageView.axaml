<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:TombLauncher.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mdxaml="https://github.com/whistyun/Markdown.Avalonia"
             xmlns:pages="clr-namespace:TombLauncher.ViewModels.Pages"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             xmlns:welcomePage="clr-namespace:TombLauncher.Views.Pages.WelcomePage"
             xmlns:controls="clr-namespace:TombLauncher.Controls;assembly=TombLauncher.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TombLauncher.Views.Pages.WelcomePageView"
             x:Name="Root"
             x:DataType="pages:WelcomePageViewModel">
    <Design.DataContext>
        <pages:WelcomePageViewModel />
    </Design.DataContext>
    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Loaded">
            <EventTriggerBehavior.Actions>
                <InvokeCommandAction Command="{Binding InitCommand}" />
            </EventTriggerBehavior.Actions>
        </EventTriggerBehavior>
    </Interaction.Behaviors>
    <ScrollViewer>
        <StackPanel Margin="16">
            <!-- Hero Section -->
            <TextBlock Classes="h1" Text="TOMB LAUNCHER" Margin="0,8,0,4" />
            <TextBlock Text="{loc:Translate WELCOME_SUBTITLE}"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource SecondaryBrush}"
                       FontSize="14"
                       Margin="0,0,0,16" />

            <!-- Widgets -->
            <welcomePage:QuickStatsWidget />
            <welcomePage:QuickActionsWidget />
            <welcomePage:ResumeLastGameWidget />
            <welcomePage:RecentlyPlayedWidget />
            <welcomePage:FavouritesWidget />
            <welcomePage:RandomGameSuggestionWidget x:Name="RandomSuggestionSection" />

            <Border Classes="card-background" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <iconPacks:PackIconRemixIcon Kind="FileTextLine" Width="20" Height="20"
                                                      Foreground="{DynamicResource PrimaryBrush}"
                                                      VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Translate WHATS_NEW}"
                                   FontSize="16" FontWeight="DemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <controls:RingLoader Width="40" Height="40"
                                        HorizontalAlignment="Center"
                                        Margin="0,16"
                                        Message="{loc:Translate CHANGELOG_LOADING}"
                                        IsVisible="{Binding IsLoadingChangelog}" />
                    <StackPanel IsVisible="{Binding ChangelogLoadFailed}" Spacing="8">
                        <controls:EmptyStateView Icon="SignalWifiErrorLine"
                                               Title="{loc:Translate CHANGELOG_LOAD_FAILED}" />
                        <Button Content="{loc:Translate TRY_AGAIN}"
                                Command="{Binding RetryLoadChangelogCommand}"
                                Classes="secondary"
                                HorizontalAlignment="Center" />
                    </StackPanel>
                    <mdxaml:MarkdownScrollViewer ScrollViewer.IsScrollChainingEnabled="True"
                                                 IsVisible="{Binding ChangeLogMarkdown, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                 Markdown="{Binding ChangeLogMarkdown}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>