<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:TombLauncher.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mdxaml="https://github.com/whistyun/Markdown.Avalonia"
             xmlns:pages="clr-namespace:TombLauncher.ViewModels.Pages"
             xmlns:views="clr-namespace:TombLauncher.Views"
             xmlns:controls="clr-namespace:TombLauncher.Controls;assembly=TombLauncher.Controls"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             xmlns:converters="clr-namespace:TombLauncher.ValueConverters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TombLauncher.Views.Pages.WelcomePageView"
             x:Name="Root"
             x:DataType="pages:WelcomePageViewModel">
    <Design.DataContext>
        <pages:WelcomePageViewModel />
    </Design.DataContext>
    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Loaded">
            <EventTriggerBehavior.Actions>
                <InvokeCommandAction Command="{Binding InitCmd}" />
            </EventTriggerBehavior.Actions>
        </EventTriggerBehavior>
    </Interaction.Behaviors>
    <ScrollViewer>
        <StackPanel Margin="16">
            <!-- Hero Section -->
            <TextBlock Classes="h1" Text="TOMB LAUNCHER" FontSize="48" Margin="0,8,0,4" />
            <TextBlock Text="{loc:Translate WELCOME_SUBTITLE}"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource SecondaryBrush}"
                       FontSize="14"
                       Margin="0,0,0,16" />

            <!-- Quick Stats -->
            <UniformGrid Columns="4" Margin="0,0,0,16"
                         IsVisible="{Binding ShowQuickStats}">
                <controls:StatCard Icon="GamepadLine"
                                   Value="{Binding QuickStats.InstalledGamesCount}"
                                   Label="{loc:Translate GAMES_INSTALLED}" />
                <controls:StatCard Icon="TimeLine"
                                   Value="{Binding QuickStats.TotalPlayTime, Converter={StaticResource TimeSpanToHumanReadableStringConverter}}"
                                   Label="{loc:Translate TOTAL_TIME_PLAYED}" />
                <controls:StatCard Icon="TrophyLine"
                                   Value="{Binding QuickStats.CompletedGamesCount}"
                                   Label="{loc:Translate COMPLETED_GAMES}" />
                <controls:StatCard Icon="HeartLine"
                                   Value="{Binding QuickStats.FavouriteGamesCount}"
                                   Label="{loc:Translate FAVOURITE_GAMES}" />
            </UniformGrid>

            <!-- Quick Actions -->
            <UniformGrid Columns="3" Margin="0,0,0,16"
                         IsVisible="{Binding ShowQuickActions}">
                <Button Command="{Binding AddGameCommand}" Margin="4" Padding="16"
                        Classes="card-background" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <iconPacks:PackIconRemixIcon Kind="AddCircleLine" Width="24" Height="24"
                                                      HorizontalAlignment="Center"
                                                      Foreground="{DynamicResource PrimaryBrush}" />
                        <TextBlock Text="{loc:Translate ADD_GAME}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SearchOnlineCommand}" Margin="4" Padding="16"
                        Classes="card-background" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <iconPacks:PackIconRemixIcon Kind="SearchLine" Width="24" Height="24"
                                                      HorizontalAlignment="Center"
                                                      Foreground="{DynamicResource PrimaryBrush}" />
                        <TextBlock Text="{loc:Translate SEARCH_ONLINE}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding RandomGameCommand}" Margin="4" Padding="16"
                        Classes="card-background" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <iconPacks:PackIconRemixIcon Kind="ShuffleLine" Width="24" Height="24"
                                                      HorizontalAlignment="Center"
                                                      Foreground="{DynamicResource PrimaryBrush}" />
                        <TextBlock Text="{loc:Translate RANDOM_GAME}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
            </UniformGrid>

            <!-- Resume Last Game -->
            <Border Classes="card-background" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    IsVisible="{Binding LatestPlayedGame, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <iconPacks:PackIconRemixIcon Kind="PlayLargeFill" Width="20" Height="20"
                                                      Foreground="{DynamicResource PrimaryBrush}"
                                                      VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Translate RESUME_YOUR_LAST_GAME}"
                                   FontSize="16" FontWeight="DemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <views:GameCardView DataContext="{Binding LatestPlayedGame}"
                                        HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Recently Played -->
            <Border Classes="card-background" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    IsVisible="{Binding ShowRecentlyPlayed}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <iconPacks:PackIconRemixIcon Kind="HistoryLine" Width="20" Height="20"
                                                      Foreground="{DynamicResource PrimaryBrush}"
                                                      VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Translate RECENTLY_PLAYED}"
                                   FontSize="16" FontWeight="DemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Empty state -->
                    <controls:EmptyStateView Icon="HistoryLine"
                                              Subtitle="{loc:Translate NO_RECENTLY_PLAYED_GAMES}"
                                              IsVisible="{Binding !HasRecentlyPlayedGames}"
                                              Margin="0,16" />

                    <!-- Carousel -->
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          IsVisible="{Binding HasRecentlyPlayedGames}">
                        <Button Grid.Column="0" Command="{Binding PreviousRecentGameCommand}"
                                VerticalAlignment="Center" Padding="8" Margin="0,0,8,0">
                            <iconPacks:PackIconRemixIcon Kind="ArrowLeftSLine" Width="20" Height="20" />
                        </Button>
                        <Carousel Grid.Column="1"
                                  ItemsSource="{Binding RecentlyPlayedGames}"
                                  SelectedIndex="{Binding RecentlyPlayedIndex}">
                            <Carousel.ItemTemplate>
                                <DataTemplate>
                                    <views:GameCardView HorizontalAlignment="Center" />
                                </DataTemplate>
                            </Carousel.ItemTemplate>
                        </Carousel>
                        <Button Grid.Column="2" Command="{Binding NextRecentGameCommand}"
                                VerticalAlignment="Center" Padding="8" Margin="8,0,0,0">
                            <iconPacks:PackIconRemixIcon Kind="ArrowRightSLine" Width="20" Height="20" />
                        </Button>
                    </Grid>

                    <!-- Pagination dots -->
                    <!-- Brush providers (hidden) -->
                    <Border x:Name="ActiveBrushProvider" Background="{DynamicResource PrimaryBrush}"
                            IsVisible="False" Width="0" Height="0" />
                    <Border x:Name="InactiveBrushProvider" Background="{DynamicResource MutedTextBrush}"
                            IsVisible="False" Width="0" Height="0" />
                    <ItemsControl ItemsSource="{Binding PaginationIndices}"
                                  HorizontalAlignment="Center"
                                  IsVisible="{Binding HasRecentlyPlayedGames}"
                                  Margin="0,4,0,0">
                        <ItemsControl.Resources>
                            <converters:IndexMatchToBrushConverter x:Key="DotFillConverter" />
                        </ItemsControl.Resources>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:Int32">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <MultiBinding Converter="{StaticResource DotFillConverter}">
                                            <Binding Path="." />
                                            <Binding Path="DataContext.RecentlyPlayedIndex"
                                                     ElementName="Root" />
                                            <Binding Path="Background"
                                                     ElementName="ActiveBrushProvider" />
                                            <Binding Path="Background"
                                                     ElementName="InactiveBrushProvider" />
                                        </MultiBinding>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- What's New -->
            <Border Classes="card-background" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <iconPacks:PackIconRemixIcon Kind="FileTextLine" Width="20" Height="20"
                                                      Foreground="{DynamicResource PrimaryBrush}"
                                                      VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Translate WHATS_NEW}"
                                   FontSize="16" FontWeight="DemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <mdxaml:MarkdownScrollViewer ScrollViewer.IsScrollChainingEnabled="True"
                                                 Source="{Binding ChangeLogPath}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>