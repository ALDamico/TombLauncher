<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:TombLauncher.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:TombLauncher.ViewModels.Pages"
             xmlns:avalonia="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TombLauncher.Views.Pages.StatisticsPageView"
             x:DataType="pages:StatisticsPageViewModel">
    <Design.DataContext>
        <pages:StatisticsPageViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Loaded">
            <EventTriggerBehavior.Actions>
                <InvokeCommandAction Command="{Binding InitCommand}" />
            </EventTriggerBehavior.Actions>
        </EventTriggerBehavior>
    </Interaction.Behaviors>

    <Grid RowDefinitions="Auto, *">
        <TextBlock Grid.Row="0" Classes="page-title" Text="{loc:Translate STATISTICS, Casing=Upper}" />
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="8" Margin="0,4,0,16">

                <!-- ── Summary stats card ─────────────────────────── -->
                <Border Classes="card-background" CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" MinHeight="36"/>
                            <RowDefinition Height="Auto" MinHeight="36"/>
                            <RowDefinition Height="Auto" MinHeight="36"/>
                            <RowDefinition Height="Auto" MinHeight="36"/>
                            <RowDefinition Height="Auto" MinHeight="36"/>
                            <RowDefinition Height="Auto" MinHeight="36"/>
                            <RowDefinition Height="Auto" MinHeight="36"/>
                            <RowDefinition Height="Auto" MinHeight="36"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="Auto" MinWidth="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icons -->
                        <iconPacks:PackIconRemixIcon Grid.Row="0" Grid.Column="0" Kind="InformationLine"   Classes="stat-icon" Margin="0, 0, 8, 0"/>
                        <iconPacks:PackIconRemixIcon Grid.Row="1" Grid.Column="0" Kind="TerminalBoxLine"   Classes="stat-icon" Margin="0, 0, 8, 0"/>
                        <iconPacks:PackIconRemixIcon Grid.Row="2" Grid.Column="0" Kind="Database2Line"     Classes="stat-icon" Margin="0, 0, 8, 0"/>
                        <iconPacks:PackIconRemixIcon Grid.Row="3" Grid.Column="0" Kind="HardDriveLine"     Classes="stat-icon" Margin="0, 0, 8, 0"/>
                        <iconPacks:PackIconRemixIcon Grid.Row="4" Grid.Column="0" Kind="GamepadLine"       Classes="stat-icon" Margin="0, 0, 8, 0"/>
                        <iconPacks:PackIconRemixIcon Grid.Row="5" Grid.Column="0" Kind="TimerLine"         Classes="stat-icon" Margin="0, 0, 8, 0"/>
                        <iconPacks:PackIconRemixIcon Grid.Row="6" Grid.Column="0" Kind="TrophyLine"        Classes="stat-icon" Margin="0, 0, 8, 0"/>
                        <iconPacks:PackIconRemixIcon Grid.Row="7" Grid.Column="0" Kind="Goblet2Line"       Classes="stat-icon" Margin="0, 0, 8, 0"
                                                    IsVisible="{Binding IsWineSupported}"/>

                        <!-- Labels -->
                        <TextBlock Grid.Row="0" Grid.Column="1" Classes="text-muted" Margin="0, 0, 8, 0" Text="{loc:Translate APPLICATION_VERSION}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Classes="text-muted" Margin="0, 0, 8, 0" Text="{loc:Translate DOTNET_VERSION}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Classes="text-muted" Margin="0, 0, 8, 0" Text="{loc:Translate DATABASE_SIZE}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Classes="text-muted" Margin="0, 0, 8, 0" Text="{loc:Translate GAMES_SIZE}"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Classes="text-muted" Margin="0, 0, 8, 0" Text="{loc:Translate LAST_PLAYED_GAME}"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Classes="text-muted" Margin="0, 0, 8, 0" Text="{loc:Translate LONGEST_PLAY_SESSION}"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Classes="text-muted" Margin="0, 0, 8, 0" Text="{loc:Translate MOST_PLAYED_GAME}"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Classes="text-muted" Margin="0, 0, 8, 0" Text="{loc:Translate WINE_VERSION}"
                                   IsVisible="{Binding IsWineSupported}"/>

                        <!-- Values -->
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ApplicationVersion}" FontWeight="Medium"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding NetVersion}"         FontWeight="Medium"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" FontWeight="Medium"
                                   Text="{Binding DatabaseSize, Converter={StaticResource FileSizeFormatter}, Mode=OneWay}"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" FontWeight="Medium"
                                   Text="{Binding GamesSize, Converter={StaticResource FileSizeFormatter}, Mode=OneWay}"/>
                        <TextBlock Grid.Row="7" Grid.Column="2" Text="{Binding WineVersion}" FontWeight="Medium"
                                   IsVisible="{Binding IsWineSupported}"/>

                        <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal" Spacing="6">
                            <Button Classes="hyperlink"
                                    VerticalAlignment="Center"
                                    Content="{Binding Statistics.LatestPlayedGame.Title}"
                                    Command="{Binding OpenGameCommand}"
                                    CommandParameter="{Binding Statistics.LatestPlayedGame.Id}"/>
                            <TextBlock Classes="text-muted"
                                       IsVisible="{Binding Statistics.LatestPlayedGame, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <Run Text="("/>
                                <Run Text="{Binding Statistics.LatestPlayedGame.LastPlayed, Converter={StaticResource DateTimeToStringConverter}, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Row="5" Grid.Column="2" Orientation="Horizontal" Spacing="6">
                            <Button Classes="hyperlink"
                                    VerticalAlignment="Center"
                                    Content="{Binding Statistics.LongestPlaySession.Title}"
                                    Command="{Binding OpenGameCommand}"
                                    CommandParameter="{Binding Statistics.LongestPlaySession.Id}"/>
                            <TextBlock Classes="text-muted"
                                       IsVisible="{Binding Statistics.LongestPlaySession, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <Run Text="("/>
                                <Run Text="{Binding Statistics.LongestPlaySession.Duration, Converter={StaticResource TimeSpanToHumanReadableStringConverter}, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Row="6" Grid.Column="2" Orientation="Horizontal" Spacing="6">
                            <Button Classes="hyperlink"
                                    VerticalAlignment="Center"
                                    Content="{Binding Statistics.MostLaunches.Title}"
                                    Command="{Binding OpenGameCommand}"
                                    CommandParameter="{Binding Statistics.MostLaunches.Id}"/>
                            <TextBlock Classes="text-muted"
                                       IsVisible="{Binding Statistics.MostLaunches, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <Run Text="("/>
                                <Run Text="{Binding Statistics.MostLaunches.TotalSessions, Converter={StaticResource LocalizedStringConverter}, ConverterParameter='PLAYED_NUMBER_TIMES', Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Charts ─────────────────────────────────────── -->
                <TextBlock Classes="section-heading" Text="{loc:Translate SPACE_USED_BY_GAME}"/>
                <avalonia:PieChart Series="{Binding Statistics.SpaceUsedStatistics.Series}"
                                   Height="600"/>

                <TextBlock Classes="section-heading" Text="{loc:Translate AVERAGE_PLAYTIME_BY_DAY_OF_WEEK}"/>
                <avalonia:CartesianChart Series="{Binding Statistics.DayOfWeekAveragePlayTimeStatistics.Series}"
                                         XAxes="{Binding Statistics.DayOfWeekAveragePlayTimeStatistics.XAxis}"
                                         YAxes="{Binding Statistics.DayOfWeekAveragePlayTimeStatistics.YAxis}"
                                         Height="600"/>

                <TextBlock Classes="section-heading" Text="{loc:Translate TOTAL_GAMES_PLAYED_BY_DAY_OF_WEEK}"/>
                <avalonia:CartesianChart Series="{Binding Statistics.DayOfWeekTotalGamesPlayedStatistics.Series}"
                                         XAxes="{Binding Statistics.DayOfWeekTotalGamesPlayedStatistics.XAxis}"
                                         YAxes="{Binding Statistics.DayOfWeekTotalGamesPlayedStatistics.YAxis}"
                                         Height="600"/>

                <TextBlock Classes="section-heading" Text="{loc:Translate DAILY_STATISTICS}"/>
                <avalonia:CartesianChart Series="{Binding Statistics.DailyAverageGameLengthStatistics.Series}"
                                         XAxes="{Binding Statistics.DailyAverageGameLengthStatistics.XAxis}"
                                         YAxes="{Binding Statistics.DailyAverageGameLengthStatistics.YAxis}"
                                         LegendPosition="Left"
                                         Height="600"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>