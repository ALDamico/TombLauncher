<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:TombLauncher.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:utils="clr-namespace:TombLauncher.Utils"
             xmlns:pages="clr-namespace:TombLauncher.ViewModels.Pages"
             xmlns:controls="clr-namespace:TombLauncher.Controls;assembly=TombLauncher.Controls"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="TombLauncher.Views.Pages.NewGameView"
             x:DataType="pages:NewGameViewModel">
    <Design.DataContext>
        <pages:NewGameViewModel />
    </Design.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Padding="0,0,30,0">
            <StackPanel Spacing="16" Margin="0,8,0,8">

                <!-- Page title -->
                <TextBlock Classes="page-title"
                           Text="{loc:Translate INSERT_NEW_GAME}" />

                <!-- Card: source file + cover image -->
                <Border Classes="card-background" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <iconPacks:PackIconRemixIcon Kind="FolderZipLine"
                                                         Width="18" Height="18"
                                                         Foreground="{DynamicResource PrimaryBrush}"
                                                         VerticalAlignment="Center" />
                            <TextBlock Text="{loc:Translate ZIP_ARCHIVE_OR_FOLDER, Casing=Upper}"
                                       FontSize="15" FontWeight="DemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <DockPanel LastChildFill="True">
                            <controls:SplitIconButton DockPanel.Dock="Right"
                                                      Icon="FolderZipLine"
                                                      Text="{loc:Translate OPEN_ZIP_FILE}"
                                                      VerticalAlignment="Top"
                                                      Command="{Binding PickZipArchiveCmd}">
                                <controls:SplitIconButton.Flyout>
                                    <MenuFlyout Placement="Bottom">
                                        <MenuItem Header="{loc:Translate OPEN_FOLDER}"
                                                  Command="{Binding PickFolderCmd}">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconRemixIcon Kind="FolderLine" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </MenuFlyout>
                                </controls:SplitIconButton.Flyout>
                            </controls:SplitIconButton>
                            <TextBox Text="{Binding Source}" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Card: game metadata + cover image -->
                <Border Classes="card-background" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                            <iconPacks:PackIconRemixIcon Kind="InformationLine"
                                                         Width="18" Height="18"
                                                         Foreground="{DynamicResource PrimaryBrush}"
                                                         VerticalAlignment="Center" />
                            <TextBlock Text="{loc:Translate GAME_DETAILS}"
                                       FontSize="15" FontWeight="DemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <DockPanel LastChildFill="True">
                            <!-- Cover image picker -->
                            <controls:ImagePicker DockPanel.Dock="Right"
                                                  Source="{Binding GameMetadata.TitlePic, TargetNullValue={x:Static utils:ImageUtils.NullBitmap}, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  DialogService="{Binding PopupService}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"
                                                  MaxHeight="220"
                                                  MaxWidth="300" />

                            <!-- Form fields -->
                            <Grid Margin="0,0,16,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Title -->
                                <controls:LabeledTextBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                                         Text="{Binding GameMetadata.Title}"
                                                         Label="{loc:Translate TITLE}" />

                                <!-- Author + Release Date -->
                                <controls:LabeledTextBox Grid.Row="1" Grid.Column="0"
                                                         Text="{Binding GameMetadata.Author}"
                                                         Label="{loc:Translate AUTHOR}" />
                                <controls:LabeledCalendarDatePicker Grid.Row="1" Grid.Column="1"
                                                                    SelectedDate="{Binding GameMetadata.ReleaseDate}"
                                                                    Label="{loc:Translate RELEASE_DATE}"
                                                                    Margin="20,0,0,0" />

                                <!-- Length -->
                                <Grid Grid.Row="2" Grid.Column="0" Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Classes="small" Text="{loc:Translate LENGTH}" />
                                    <ComboBox Grid.Row="1"
                                              HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding AvailableLengths}"
                                              SelectedValueBinding="{Binding Value}"
                                              SelectedValue="{Binding GameMetadata.Length}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Description}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>

                                <!-- Difficulty -->
                                <Grid Grid.Row="2" Grid.Column="1" Margin="20,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Classes="small" Text="{loc:Translate DIFFICULTY}" />
                                    <ComboBox Grid.Row="1"
                                              HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding AvailableDifficulties}"
                                              SelectedValueBinding="{Binding Value}"
                                              SelectedValue="{Binding GameMetadata.Difficulty}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Description}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>

                                <!-- Setting/Milieu -->
                                <controls:LabeledTextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                                         Margin="0,8,0,0"
                                                         Text="{Binding GameMetadata.Setting}"
                                                         Label="{loc:Translate SETTING_MILIEU}" />
                            </Grid>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Card: Synopsis -->
                <Border Classes="card-background" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <iconPacks:PackIconRemixIcon Kind="FileTextLine"
                                                         Width="18" Height="18"
                                                         Foreground="{DynamicResource PrimaryBrush}"
                                                         VerticalAlignment="Center" />
                            <TextBlock Text="{loc:Translate SYNOPSIS, Casing=Upper}"
                                       FontSize="15" FontWeight="DemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox Text="{Binding GameMetadata.Description}"
                                 AcceptsReturn="True"
                                 MinHeight="120" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Action bar — same pattern as SettingsPageView -->
        <DockPanel Grid.Row="1" LastChildFill="False" Margin="0,8,30,0">
            <controls:IconButton DockPanel.Dock="Right"
                                 Classes="btn-primary"
                                 Margin="10"
                                 Padding="16,8"
                                 Icon="Save3Line"
                                 Text="{loc:Translate INSTALL}"
                                 Command="{Binding SaveCmd}" />
        </DockPanel>
    </Grid>
</UserControl>