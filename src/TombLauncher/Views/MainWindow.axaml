<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
        xmlns:viewModels="clr-namespace:TombLauncher.ViewModels"
        xmlns:controls="clr-namespace:TombLauncher.Controls;assembly=TombLauncher.Controls"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        xmlns:loc="using:TombLauncher.Localization"
        xmlns:valueConverters="clr-namespace:TombLauncher.ValueConverters"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="TombLauncher.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Icon="/Assets/tomb-launcher-icon.ico"
        Title="{Binding Title}"
        Background="{DynamicResource PageBackgroundBrush}"
        WindowState="{Binding CurrentWindowState, Mode=TwoWay}"
        Width="1024"
        Height="768">
    
    <Window.Resources>
        <valueConverters:FullScreenToIconConverter x:Key="FullScreenToIconConverter"/>
    </Window.Resources>

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <viewModels:MainWindowViewModel />
    </Design.DataContext>
    <SplitView IsPaneOpen="{Binding IsPaneOpen}" DisplayMode="CompactInline">
        <SplitView.Pane>

            <Grid Background="{DynamicResource SidebarBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <controls:IconButton Grid.Row="0" 
                                     Classes="icon-only"
                                     ToolTip.Tip="Menu" 
                                     Icon="MenuLine" 
                                     Command="{Binding TogglePaneCommand}"/>

                <ListBox Grid.Row="1" 
                         Margin="2 0 -100 0" 
                         ItemsSource="{Binding MenuItems}" 
                         SelectionMode="Single"
                         SelectedItem="{Binding SelectedMenuItem}">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12 8" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:MainMenuItemViewModel}">
                            <StackPanel Spacing="20" 
                                        Orientation="Horizontal" 
                                        ToolTip.Tip="{Binding ToolTip}"
                                        Background="Transparent">
                                <iconPacks:PackIconRemixIcon Kind="{Binding Icon}" />
                                <TextBlock Text="{Binding Text}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <controls:SidebarNavigationItem Grid.Row="2"
                                                Command="{Binding OpenAboutPageCommand}"
                                                Icon="{Binding AboutPageItem.Icon}"
                                                Text="{Binding AboutPageItem.Text}"
                                                IsSelected="{Binding IsAboutPageOpen}" />
                <controls:SidebarNavigationItem Grid.Row="3"
                                                Command="{Binding WebsiteLinkItem.Command}"
                                                Icon="{Binding WebsiteLinkItem.Icon}"
                                                Text="{Binding WebsiteLinkItem.Text}"
                                                ToolTip.Tip="{Binding WebsiteLinkItem.Tooltip}" />
                <controls:SidebarNavigationItem Grid.Row="4"
                                                Command="{Binding GitHubLinkItem.Command}"
                                                Icon="{Binding GitHubLinkItem.Icon}"
                                                Text="{Binding GitHubLinkItem.Text}"
                                                ToolTip.Tip="{Binding GitHubLinkItem.Tooltip}" />
                <controls:SidebarNavigationItem Grid.Row="5"
                                                Command="{Binding OpenSettingsCommand}"
                                                Icon="{Binding SettingsItem.Icon}"
                                                Text="{Binding SettingsItem.Text}"
                                                IsSelected="{Binding IsSettingsOpen}" />
            </Grid>

        </SplitView.Pane>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" LastChildFill="False">
                <controls:IconOnlyButton Command="{Binding GoBackCommand}"
                                     Icon="ArrowLeftLine" />
                <ContentControl Content="{Binding NotificationListViewModel}" 
                                DockPanel.Dock="Right"/>
                <ItemsControl DockPanel.Dock="Right"
                              HorizontalAlignment="Right"
                              ItemsSource="{Binding CurrentPage.TopBarCommands}"
                              Margin="0,0,15,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:IconOnlyButton Icon="{Binding Icon}"
                                                     Command="{Binding Command}"
                                                     ToolTip.Tip="{Binding Tooltip}"
                                                     Margin="5 0" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <controls:IconOnlyButton DockPanel.Dock="Right" 
                                         Command="{Binding ToggleFullScreenCommand}" 
                                         Icon="{Binding CurrentWindowState, Converter={StaticResource FullScreenToIconConverter}}" 
                                         ToolTip.Tip="{loc:Translate TOGGLE_FULLSCREEN}"/>

            </DockPanel>
            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" IsVisible="{Binding CurrentPage.IsBusy}"
                    ZIndex="5000" Background="#A0000000">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <controls:RingLoader HorizontalAlignment="Center" VerticalAlignment="Center" Message="{Binding CurrentPage.BusyMessage, FallbackValue=''}" />
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="{Binding CurrentPage.CurrentFileName}"
                               IsVisible="{Binding CurrentPage.CurrentFileName, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsVisible="{Binding CurrentPage.PercentageComplete, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Run Text="{Binding CurrentPage.PercentageComplete, StringFormat={}{0:0.00}}" />
                        <Run Text="%" />
                    </TextBlock>
                    <Button Content="{loc:Translate CANCEL}" Command="{Binding CurrentPage.CancelCmd}"
                            IsVisible="{Binding CurrentPage.IsCancelable}">
                    </Button>
                </StackPanel>
            </Border>
            <TransitioningContentControl Grid.Row="1" 
                                         Margin="15" 
                                         Content="{Binding CurrentPage}">
                <TransitioningContentControl.PageTransition>
                    <CrossFade Duration="0:00:00.25" />
                </TransitioningContentControl.PageTransition>
                <TransitioningContentControl.IsEnabled>
                    <Binding Path="CurrentPage.IsBusy" Converter="{x:Static ObjectConverters.Equal}">
                        <Binding.ConverterParameter>
                            <system:Boolean>False</system:Boolean>
                        </Binding.ConverterParameter>
                    </Binding>
                </TransitioningContentControl.IsEnabled>
            </TransitioningContentControl>
        </Grid>
    </SplitView>
</Window>