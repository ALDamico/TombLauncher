<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:TombLauncher.ViewModels"
             xmlns:enums="clr-namespace:TombLauncher.Contracts.Enums;assembly=TombLauncher.Contracts"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="80"
             x:Class="TombLauncher.Views.InstallProgressView"
             x:DataType="viewModels:InstallProgressViewModel">
    <Design.DataContext>
        <viewModels:InstallProgressViewModel />
    </Design.DataContext>

    <StackPanel Spacing="4">

        <!-- Status message -->
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <iconPacks:PackIconRemixIcon Kind="CheckLine"
                                        Width="16" Height="16"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource SuccessBrush}"
                                        IsVisible="{Binding InstallStatus, Converter={x:Static ObjectConverters.Equal},
                                                            ConverterParameter={x:Static enums:InstallStatus.Completed}}" />
            <TextBlock Text="{Binding Message}"
                       FontWeight="SemiBold"
                       FontSize="13" />
        </StackPanel>

        <!-- Download phase -->
        <StackPanel Spacing="3"
                    IsVisible="{Binding InstallStatus, Converter={x:Static ObjectConverters.Equal},
                                        ConverterParameter={x:Static enums:InstallStatus.Downloading}}">
            <ProgressBar Minimum="0"
                         Maximum="{Binding TotalBytes, FallbackValue=100}"
                         Value="{Binding CurrentBytes, FallbackValue=0}" />
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="3"
                            DockPanel.Dock="Right"
                            IsVisible="{Binding TotalBytes, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter=0}">
                    <iconPacks:PackIconRemixIcon Kind="Download2Line"
                                                Width="12" Height="12"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Classes="small text-muted"
                               Text="{Binding DownloadSpeed, Converter={StaticResource TransferSpeedFormatter}}" />
                </StackPanel>
                <TextBlock Classes="small text-muted" DockPanel.Dock="Left">
                    <Run Text="{Binding CurrentBytes, Converter={StaticResource FileSizeFormatter}, Mode=OneWay}" />
                    <Run Text="/" />
                    <Run Text="{Binding TotalBytes, Converter={StaticResource FileSizeFormatter}, Mode=OneWay}" />
                </TextBlock>
            </DockPanel>
        </StackPanel>

        <!-- Install phase -->
        <StackPanel Spacing="3"
                    IsVisible="{Binding InstallStatus, Converter={x:Static ObjectConverters.Equal},
                                        ConverterParameter={x:Static enums:InstallStatus.Installing}}">
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding InstallPercentage}" />
            <DockPanel>
                <TextBlock Classes="small text-muted" DockPanel.Dock="Left">
                    <Run Text="{Binding InstallPercentage, StringFormat='{}{0:0}'}" />
                    <Run Text="%" />
                </TextBlock>
                <TextBlock Classes="small text-muted"
                           DockPanel.Dock="Right"
                           TextAlignment="Right"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding CurrentFileName}" />
            </DockPanel>
        </StackPanel>

        <!-- Indeterminate phase -->
        <ProgressBar IsIndeterminate="True"
                     IsVisible="{Binding InstallStatus, Converter={x:Static ObjectConverters.Equal},
                                         ConverterParameter={x:Static enums:InstallStatus.Indeterminate}}" />

    </StackPanel>
</UserControl>