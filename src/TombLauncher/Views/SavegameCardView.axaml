<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:TombLauncher.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:TombLauncher.ViewModels"
             xmlns:controls="clr-namespace:TombLauncher.Controls;assembly=TombLauncher.Controls"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             xmlns:valueConverters="clr-namespace:TombLauncher.ValueConverters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TombLauncher.Views.SavegameCardView"
             x:DataType="viewModels:SavegameViewModel">
    <Design.DataContext>
        <viewModels:SavegameViewModel />
    </Design.DataContext>
    <UserControl.Resources>
        <valueConverters:BooleanToIconConverter x:Key="BooleanToIconConverter"
                                                        TrueValue="FlagFill"
                                                        FalseValue="FlagLine" />
        <valueConverters:BooleanToStringConverter x:Key="MarkUnmarkTooltipConverter"
                                                          TrueValue="UNMARK_AS_START_OF_LEVEL_SAVE"
                                                          FalseValue="MARK_AS_START_OF_LEVEL_SAVE" />
    </UserControl.Resources>
    <Border CornerRadius="3" 
            Padding="10" 
            Margin="10" 
            Width="250"
            Classes="card-background">
        <Border.Styles>
            <Style Selector="TextBlock">
                <Setter Property="Foreground" Value="White"/>
            </Style>
            <Style Selector="Border :is(Button)">
                <Setter Property="Opacity" Value="0"/>
                <Setter Property="Transitions">
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.25" />
                    </Transitions>
                </Setter>
            </Style>
            <Style Selector="Border:pointerover :is(Button)">
                <Setter Property="Opacity" Value="1"/>
            </Style>
        </Border.Styles>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0">
                <controls:LabeledTextBlock Label="{loc:Translate SLOT_NUMBER}" 
                                           Text="{Binding SlotNumber}"/>
                <TextBlock Classes="small" Text="{loc:Translate LEVEL_NAME}" />
                <DockPanel LastChildFill="True">
                    <TextBlock Text="{Binding SaveNumber}"
                               DockPanel.Dock="Right" />
                    <TextBlock Text="{Binding LevelName}" />
                </DockPanel>
                <controls:LabeledTextBlock Label="{loc:Translate FILE_NAME}" 
                                           Text="{Binding Filename, Converter={StaticResource FilenameConverter}}"/>
                <controls:LabeledTextBlock Label="{loc:Translate DATE_AND_TIME}" Text="{Binding BackedUpOn}"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                <controls:IconOnlyButton Icon="HistoryLine"
                                         ToolTip.Tip="{loc:Translate RESTORE}"
                                         Command="{Binding RestoreSavegameCmd}"
                                         CommandParameter="{Binding Id}">
                </controls:IconOnlyButton>

                <ToggleButton IsChecked="{Binding IsStartOfLevel}"
                              Command="{Binding UpdateStartOfLevelStateCmd}"
                              CommandParameter="{Binding .}"
                              ToolTip.Tip="{Binding IsStartOfLevel, Converter={StaticResource MarkUnmarkTooltipConverter}}">
                    <ToggleButton.Content>
                        <iconPacks:PackIconRemixIcon
                            Kind="{Binding IsStartOfLevel, Converter={StaticResource BooleanToIconConverter}}"/>
                    </ToggleButton.Content>
                </ToggleButton>
                <controls:IconOnlyButton Icon="DeleteBinLine"
                                         Command="{Binding DeleteSavegameCmd}"
                                         CommandParameter="{Binding .}"
                                         IsVisible="{Binding !IsStartOfLevel}"
                                         Classes="btn-danger" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>