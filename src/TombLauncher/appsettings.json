  "Downloaders": {
    "Sources": [
      {
        "DisplayName": "TRCustoms.org",
        "BaseUrl": "https://trcustoms.org/",
        "Priority": 1,
        "ClassName": "TombLauncher.Installers.Downloaders.TRCustoms.org.TrCustomsGameDownloader",
        "SupportedFeatures": "Game engine, Level name, Setting, Rating, Game length",
        "IsChecked": true,
        "CanUserCheck": true
      },
      {
        "DisplayName": "TRLE.net",
        "BaseUrl": "https://trle.net",
        "Priority": 2,
        "ClassName": "TombLauncher.Installers.Downloaders.TRLE.net.TrleGameDownloader",
        "SupportedFeatures": "Game engine, Author, Level name, Difficulty, Rating, Game length",
        "IsChecked": true,
        "CanUserCheck": true
      },
      {
        "DisplayName": "AspideTR",
        "BaseUrl": "https://www.aspidetr.com/",
        "Priority": 3,
        "ClassName": "TombLauncher.Installers.Downloaders.AspideTR.com.AspideTrGameDownloader",
        "SupportedFeatures": "Game engine, Author, Level name, Difficulty, Setting, Game length",
        "IsChecked": true,
        "CanUserCheck": true
      }
    ]
  },
  "GameDetails": {
    "AskForConfirmationBeforeWalkthrough": true,
    "DocumentationPatterns": [
      {
        "IsChecked": true,
        "CanUserCheck": false,
        "Value": "read*me.*"
      },
      {
        "IsChecked": true,
        "CanUserCheck": false,
        "Value": "*manual.*"
      }
    ],
    "DocumentationFolderExclusions": [
      {
        "IsChecked": true,
        "CanUserCheck": false,
        "Value": "source"
      },
      {
        "IsChecked": true,
        "CanUserCheck": false,
        "Value": "controller"
      }
    ]
  },
  "Savegames": {
    "BackupSavegamesEnabled": true,
    "NumberOfVersionsToKeep": null,
    "SavegameProcessingDelay": 500
  },
  "WelcomePage": {
    "ShowQuickStats": true,
    "ShowQuickActions": true,
    "ShowRecentlyPlayed": true,
    "ShowFavourites": true,
    "RecentlyPlayedCount": 5,
    "FavouritesCount": 5,
    "ShowRandomSuggestion": true,
    "RandomGameMaxRerolls": 10
