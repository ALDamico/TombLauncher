    <system:String x:Key="ALLOW_TOMB_LAUNCHER_TO_BACKUP_YOUR_SAVED_GAMES">Consenti a Tomb Launcher di eseguire un backup dei tuoi salvataggi</system:String>
    <system:String x:Key="LIMIT_THE_NUMBER_OF_VERSIONS_TO_KEEP">Limita il numero di versioni da mantenere</system:String>
