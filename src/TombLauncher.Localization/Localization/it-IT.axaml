    <system:String x:Key="MARK_AS_COMPLETED">Segna come completato</system:String>
    <system:String x:Key="UNMARK_AS_COMPLETED">Rimuovi come completato</system:String>
    <system:String x:Key="MARK_ALL_AS_READ">Segna tutto come letto</system:String>
    <system:String x:Key="RESUME_YOUR_LAST_GAME">Riprendi l'ultima partita</system:String>
    <system:String x:Key="CLEAN_UP_TEMPORARY_FILES">Esegui pulizia dei file temporanei</system:String>
    <system:String x:Key="CLEAN_UP_TOMB_LAUNCHER_S_TEMPORARY_FOLDER_MANUALLY">Esegui manualmente la pulizia dei file temporanei di Tomb Launcher per recuperare spazio su disco.</system:String>
    <system:String x:Key="CLEAN_UP_COMPLETED">Pulizia completata!</system:String>
    <system:String x:Key="THE_CLEAN_UP_PROCESS_HAS_COMPLETED_SUCCESSFULLY">Il processo di pulizia è stato completato con successo!</system:String>
    <system:String x:Key="SPACE_USED_BY_GAME">Spazio occupato per gioco</system:String>
    <system:String x:Key="WINE_EXECUTABLE_PATH">Percorso dell'eseguibile di Wine</system:String>
    <system:String x:Key="DESCRIPTION_FONT_SIZE">Dimensione carattere descrizione</system:String>
    <system:String x:Key="DESCRIPTION_FONT_SIZE_TOOLTIP">Controlla la dimensione del carattere di base nelle descrizioni. Gli heading si adattano proporzionalmente.</system:String>
    <system:String x:Key="WINE_TOOLTIP_CONTENT">Wine è un layer di compatibilità che permette di eseguire programmi Windows su Linux. Per giocare ai livelli custom di TRLE, è necessario averlo installato sul proprio sistema.</system:String>
    <system:String x:Key="GENERAL">Avvio</system:String>
    <system:String x:Key="COMMUNITY_PATCH">Community patch</system:String>
    <system:String x:Key="COMPATIBILITY">Compatibilità</system:String>
    <system:String x:Key="WINE_NOT_FOUND">Wine non trovato</system:String>
    <system:String x:Key="WINE_NOT_FOUND_DESCRIPTION">TombLauncher utilizza Wine per eseguire i livelli TRLE su Linux. Se non è installato sul tuo sistema, non potrai giocare.</system:String>
    <system:String x:Key="AUTODETECT_WINE">Rileva automaticamente</system:String>
    <system:String x:Key="WINE_PREFIX_PATH">Cartella dati Wine (opzionale)</system:String>
    <system:String x:Key="WINE_PREFIX_TOOLTIP_CONTENT">Una cartella dedicata in cui Wine memorizza le impostazioni e i file Windows virtuali di questo gioco, tenendoli separati dagli altri. Lascia vuoto per usare la cartella predefinita comune.</system:String>
    <system:String x:Key="WINE_VERSION">Versione di Wine</system:String>
    <system:String x:Key="WINEPREFIX_LAUNCH_OPTION">Cartella dati Wine (solo questo gioco)</system:String>
    <system:String x:Key="COMPATIBILITY_TOOL">Strumento di compatibilità</system:String>
    <system:String x:Key="PROTON_EXECUTABLE_PATH">Percorso eseguibile Proton</system:String>
    <system:String x:Key="PROTON_TOOLTIP_CONTENT">Proton è il layer di compatibilità di Valve per eseguire giochi Windows su Linux. Seleziona un'installazione rilevata dalla libreria Steam, o inserisci il percorso manualmente.</system:String>
    <system:String x:Key="PROTON_DATA_PATH">Cartella dati Proton (opzionale)</system:String>
    <system:String x:Key="PROTON_DATA_PATH_TOOLTIP">Cartella dedicata dove Proton salva le impostazioni e i file Windows virtuali di questo gioco (STEAM_COMPAT_DATA_PATH). Lascia vuoto per usare la cartella predefinita globale.</system:String>
    <system:String x:Key="PROTON_VERSION">Versione Proton</system:String>
    <system:String x:Key="PROTON_NOT_FOUND">Proton non trovato</system:String>
    <system:String x:Key="PROTON_NOT_FOUND_DESCRIPTION">TombLauncher è configurato per usare Proton, ma non è stata trovata alcuna installazione. Assicurati di avere Proton installato tramite Steam, oppure imposta il percorso manualmente in Impostazioni → Compatibilità.</system:String>
    <system:String x:Key="UNZIP_FALLBACK_METHOD">Metodo di decompressione di fallback</system:String>
    <system:String x:Key="INSERT_NEW_GAME">INSERISCI UN NUOVO GIOCO</system:String>
    <system:String x:Key="INSTALL">Installa</system:String>
    <system:String x:Key="THIS_LEVEL_WAS_FOUND_BY_ONE_OR_MORE_DOWNLOADERS_BU">Questo livello è stato trovato da uno o più downloader, ma non è disponibile un link per il download.</system:String>
    
