    <system:String x:Key="TALK_TO_LAURA">Chatta con Laura</system:String>
    <system:String x:Key="AI_CHAT_EMPTY_TITLE">Chiedi a Laura</system:String>
    <system:String x:Key="AI_CHAT_EMPTY_SUBTITLE">Puoi fare domande generali su Tomb Launcher, oppure aprire questa chat dalla pagina di dettaglio di un gioco per ricevere aiuto specifico.</system:String>
