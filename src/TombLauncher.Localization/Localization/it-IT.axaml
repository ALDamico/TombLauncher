    <system:String x:Key="DELETE_SAVEGAMES_MARKED_AS_START_OF_LEVEL">Elimina anche i salvataggi contrassegnati come Inizio di livello</system:String>
    <system:String x:Key="RESCANS_YOUR_BACKED_UP_SAVEGAMES_AND_SYNCS_THEIR_C">Scansiona i salvataggi noti a Tomb Launcher e ne sincronizza il contenuto col database.</system:String>
