    <system:String x:Key="DELETE_SAVEGAMES_MARKED_AS_START_OF_LEVEL">Als Levelanfang markierte Spielstände löschen</system:String>
    <system:String x:Key="RESCANS_YOUR_BACKED_UP_SAVEGAMES_AND_SYNCS_THEIR_C">Durchsucht deine gesicherten Spielstände und synchronisiert deren Inhalt mit der Datenbank von Tomb Launcher</system:String>
