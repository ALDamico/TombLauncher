    <system:String x:Key="CLEAN_UP_TOMB_LAUNCHER_S_TEMPORARY_FOLDER_MANUALLY">Bereinige den temporären Ordner von Tomb Launcher manuell, um Speicherplatz freizugeben.</system:String>
