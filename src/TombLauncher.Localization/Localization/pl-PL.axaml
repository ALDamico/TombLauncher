    <system:String x:Key="ARE_YOU_SURE_YOU_WANT_TO_DELETE_ALL_SAVEGAMES_THIS">Czy na pewno chcesz usunąć wszystkie zapisy? Tej czynności nie można cofnąć.</system:String>
    <system:String x:Key="DELETE_SAVEGAMES_MARKED_AS_START_OF_LEVEL">Usuń zapisy oznaczone jako początek poziomu</system:String>
    <system:String x:Key="RESCANS_YOUR_BACKED_UP_SAVEGAMES_AND_SYNCS_THEIR_C">Ponownie skanuje Twoje zapisane kopie zapasowe i synchronizuje ich zawartość z bazą danych Tomb Launcher</system:String>
