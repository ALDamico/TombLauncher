    <system:String x:Key="AI_CHAT_EMPTY_TITLE">Zapytaj Laurę o cokolwiek</system:String>
    <system:String x:Key="AI_CHAT_EMPTY_SUBTITLE">Zadawaj ogólne pytania dotyczące Tomb Launcher lub otwórz ten czat ze strony szczegółów gry, aby uzyskać pomoc dotyczącą konkretnej gry.</system:String>
