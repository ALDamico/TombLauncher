    <system:String x:Key="CLEAN_UP_TOMB_LAUNCHER_S_TEMPORARY_FOLDER_MANUALLY">Ręcznie wyczyść folder tymczasowy Tomb Launcher, aby odzyskać miejsce na dysku.</system:String>
