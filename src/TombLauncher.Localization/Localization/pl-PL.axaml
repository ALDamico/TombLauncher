    <system:String x:Key="SETUP_EXECUTABLE_TOOLTIP">Program do uruchomienia w celu uruchomienia narzędzia konfiguracyjnego gry.</system:String>
    <system:String x:Key="SETUP_EXECUTABLE_ARGS">Argumenty pliku wykonywalnego konfiguracji</system:String>
    <system:String x:Key="SETUP_EXECUTABLE_ARGS_TOOLTIP">Argumenty przekazywane do wiersza poleceń w celu uruchomienia narzędzia konfiguracyjnego. Dla klasycznych silników jest to "-setup".</system:String>
    <system:String x:Key="CAN_LAUNCH_SETUP">Może uruchomić narzędzie konfiguracyjne</system:String>
    <system:String x:Key="COMMUNITY_PATCH_SETUP_EXECUTABLE">Plik wykonywalny konfiguracji patcha społeczności</system:String>
    <system:String x:Key="COMMUNITY_PATCH_SETUP_EXECUTABLE_TOOLTIP">Włącz tę opcję, jeśli ten poziom używa ulepszonego silnika społeczności, jak niektóre wersje TRX lub Tomb3 Community Edition, do uruchomienia narzędzia konfiguracyjnego.</system:String>
