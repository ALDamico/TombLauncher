    <system:String x:Key="DESCRIPTION_FONT_SIZE">Rozmiar czcionki opisu</system:String>
    <system:String x:Key="DESCRIPTION_FONT_SIZE_TOOLTIP">Kontroluje podstawowy rozmiar czcionki używany w opisach gier. Nagłówki skalują się proporcjonalnie.</system:String>
    <system:String x:Key="WINE_TOOLTIP_CONTENT">Wine to warstwa kompatybilności umożliwiająca uruchamianie programów Windows na Linuksie. Do gry w niestandardowe poziomy TRLE musisz mieć go zainstalowanego w swoim systemie.</system:String>
    <system:String x:Key="GENERAL">Uruchamianie</system:String>
    <system:String x:Key="COMMUNITY_PATCH">Patch społeczności</system:String>
    <system:String x:Key="COMPATIBILITY">Zgodność</system:String>
    <system:String x:Key="WINE_NOT_FOUND">Nie znaleziono Wine</system:String>
    <system:String x:Key="WINE_NOT_FOUND_DESCRIPTION">TombLauncher używa Wine do uruchamiania poziomów TRLE na Linuksie. Jeśli nie jest zainstalowane w Twoim systemie, nie będziesz mógł grać.</system:String>
    <system:String x:Key="AUTODETECT_WINE">Wykryj automatycznie</system:String>
    <system:String x:Key="WINE_PREFIX_PATH">Folder danych Wine (opcjonalnie)</system:String>
    <system:String x:Key="WINE_PREFIX_TOOLTIP_CONTENT">Dedykowany folder, w którym Wine przechowuje ustawienia i wirtualne pliki Windows tej gry, oddzielając je od innych gier. Zostaw puste, aby używać wspólnego folderu domyślnego.</system:String>
    <system:String x:Key="WINE_VERSION">Wersja Wine</system:String>
    <system:String x:Key="WINEPREFIX_LAUNCH_OPTION">Folder danych Wine (tylko ta gra)</system:String>
    <system:String x:Key="COMPATIBILITY_TOOL">Narzędzie kompatybilności</system:String>
    <system:String x:Key="PROTON_EXECUTABLE_PATH">Ścieżka do pliku wykonywalnego Proton</system:String>
    <system:String x:Key="PROTON_TOOLTIP_CONTENT">Proton to warstwa kompatybilności Valve do uruchamiania gier Windows na Linuksie. Wybierz instalację wykrytą z biblioteki Steam lub wprowadź ścieżkę ręcznie.</system:String>
    <system:String x:Key="PROTON_DATA_PATH">Folder danych Proton (opcjonalnie)</system:String>
    <system:String x:Key="PROTON_DATA_PATH_TOOLTIP">Dedykowany folder, w którym Proton przechowuje ustawienia i wirtualne pliki Windows tej gry (STEAM_COMPAT_DATA_PATH). Zostaw puste, aby używać globalnego folderu domyślnego.</system:String>
    <system:String x:Key="PROTON_VERSION">Wersja Proton</system:String>
    <system:String x:Key="PROTON_NOT_FOUND">Nie znaleziono Proton</system:String>
    <system:String x:Key="PROTON_NOT_FOUND_DESCRIPTION">TombLauncher jest skonfigurowany do używania Proton, ale nie znaleziono żadnej instalacji. Upewnij się, że masz zainstalowany Proton przez Steam, lub ustaw ścieżkę ręcznie w Ustawienia → Zgodność.</system:String>
    <system:String x:Key="UNZIP_FALLBACK_METHOD">Zapasowa metoda rozpakowywania</system:String>
    <system:String x:Key="INSERT_NEW_GAME">DODAJ NOWĄ GRĘ</system:String>
    <system:String x:Key="INSTALL">Zainstaluj</system:String>
    <system:String x:Key="THIS_LEVEL_WAS_FOUND_BY_ONE_OR_MORE_DOWNLOADERS_BU">Ten poziom został znaleziony przez jeden lub więcej pobieralników, ale nie ma dostępnego linku do pobierania.</system:String>

