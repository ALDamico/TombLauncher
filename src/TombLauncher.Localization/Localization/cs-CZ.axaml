    <system:String x:Key="AI_CHAT_EMPTY_TITLE">Zeptejte se Laury na cokoliv</system:String>
    <system:String x:Key="AI_CHAT_EMPTY_SUBTITLE">Ptejte se na obecné otázky o Tomb Launcher nebo otevřete tento chat ze stránky podrobností hry a získejte pomoc s konkrétní hrou.</system:String>
    <system:String x:Key="ASK_LAURA_SOMETHING">Zeptejte se Laury na něco...</system:String>
