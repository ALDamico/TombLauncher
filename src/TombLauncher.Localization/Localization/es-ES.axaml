    <system:String x:Key="SUPPORTED_WITH_COMPATIBILITY_LAYER">Este nivel se ejecuta mediante una capa de compatibilidad.</system:String>
    <system:String x:Key="SUPPORTED_NATIVE_PATCHING_AVAILABLE">Este nivel se ejecuta mediante una capa de compatibilidad, pero hay un parche disponible para ejecutarlo de forma nativa.</system:String>
