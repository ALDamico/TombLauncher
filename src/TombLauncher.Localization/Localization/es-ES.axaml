    <system:String x:Key="TALK_TO_LAURA">Chatear con Laura</system:String>
    <system:String x:Key="AI_CHAT_EMPTY_TITLE">Pregunta a Laura lo que quieras</system:String>
    <system:String x:Key="AI_CHAT_EMPTY_SUBTITLE">Haz preguntas generales sobre Tomb Launcher, o abre este chat desde la página de detalles de un juego para obtener ayuda específica.</system:String>
