    <system:String x:Key="CLEAN_UP_TOMB_LAUNCHER_S_TEMPORARY_FOLDER_MANUALLY">Limpia manualmente la carpeta temporal de Tomb Launcher para recuperar espacio en disco.</system:String>
    <system:String x:Key="CLEAN_UP_COMPLETED">¡Limpieza completada!</system:String>
    <system:String x:Key="THE_CLEAN_UP_PROCESS_HAS_COMPLETED_SUCCESSFULLY">¡El proceso de limpieza se ha completado con éxito!</system:String>
    <system:String x:Key="SPACE_USED_BY_GAME">Espacio usado por el juego</system:String>
    <system:String x:Key="WINE_EXECUTABLE_PATH">Ruta del ejecutable de Wine</system:String>
    <system:String x:Key="DESCRIPTION_FONT_SIZE">Tamaño de fuente de la descripción</system:String>
    <system:String x:Key="DESCRIPTION_FONT_SIZE_TOOLTIP">Controla el tamaño de fuente base usado en las descripciones de juegos. Los encabezados escalan proporcionalmente.</system:String>
    <system:String x:Key="WINE_TOOLTIP_CONTENT">Wine es una capa de compatibilidad que permite ejecutar programas de Windows en Linux. Para jugar a niveles TRLE personalizados, necesitarás tenerlo instalado en tu sistema.</system:String>
    <system:String x:Key="GENERAL">Inicio</system:String>
    <system:String x:Key="COMMUNITY_PATCH">Parche de la comunidad</system:String>
    <system:String x:Key="COMPATIBILITY">Compatibilidad</system:String>
    <system:String x:Key="WINE_NOT_FOUND">Wine no encontrado</system:String>
    <system:String x:Key="WINE_NOT_FOUND_DESCRIPTION">TombLauncher usa Wine para ejecutar niveles TRLE en Linux. Si no está instalado en tu sistema, no podrás jugar.</system:String>
    <system:String x:Key="AUTODETECT_WINE">Detección automática</system:String>
    <system:String x:Key="WINE_PREFIX_PATH">Carpeta de datos de Wine (opcional)</system:String>
    <system:String x:Key="WINE_PREFIX_TOOLTIP_CONTENT">Una carpeta dedicada donde Wine almacena la configuración y los archivos de Windows virtuales de este juego, manteniéndolos separados de otros juegos. Déjalo vacío para usar la carpeta predeterminada común.</system:String>
    <system:String x:Key="WINE_VERSION">Versión de Wine</system:String>
    <system:String x:Key="WINEPREFIX_LAUNCH_OPTION">Carpeta de datos de Wine (solo este juego)</system:String>
    <system:String x:Key="COMPATIBILITY_TOOL">Herramienta de compatibilidad</system:String>
    <system:String x:Key="PROTON_EXECUTABLE_PATH">Ruta del ejecutable de Proton</system:String>
    <system:String x:Key="PROTON_TOOLTIP_CONTENT">Proton es la capa de compatibilidad de Valve para ejecutar juegos de Windows en Linux. Selecciona una instalación detectada en tu biblioteca de Steam, o introduce la ruta manualmente.</system:String>
    <system:String x:Key="PROTON_DATA_PATH">Carpeta de datos de Proton (opcional)</system:String>
    <system:String x:Key="PROTON_DATA_PATH_TOOLTIP">Una carpeta dedicada donde Proton almacena la configuración y los archivos de Windows virtuales de este juego (STEAM_COMPAT_DATA_PATH). Déjalo vacío para usar la carpeta predeterminada global.</system:String>
    <system:String x:Key="PROTON_VERSION">Versión de Proton</system:String>
    <system:String x:Key="PROTON_NOT_FOUND">Proton no encontrado</system:String>
    <system:String x:Key="PROTON_NOT_FOUND_DESCRIPTION">TombLauncher está configurado para usar Proton, pero no se encontró ninguna instalación. Asegúrate de tener Proton instalado a través de Steam, o establece la ruta manualmente en Configuración → Compatibilidad.</system:String>
    <system:String x:Key="UNZIP_FALLBACK_METHOD">Método alternativo de descompresión</system:String>
    <system:String x:Key="INSERT_NEW_GAME">INSERTAR NUEVO JUEGO</system:String>
