    <system:String x:Key="THIS_LEVEL_WAS_FOUND_BY_ONE_OR_MORE_DOWNLOADERS_BU">Este nivel fue encontrado por uno o más descargadores, pero no hay ningún enlace de descarga disponible.</system:String>

