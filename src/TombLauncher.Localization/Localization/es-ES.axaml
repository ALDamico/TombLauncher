    <system:String x:Key="ARE_YOU_SURE_YOU_WANT_TO_DELETE_ALL_SAVEGAMES_THIS">¿Estás seguro de que quieres eliminar todas las partidas guardadas? Esta acción no se puede deshacer.</system:String>
    <system:String x:Key="DELETE_SAVEGAMES_MARKED_AS_START_OF_LEVEL">Eliminar partidas marcadas como inicio de nivel</system:String>
    <system:String x:Key="RESCANS_YOUR_BACKED_UP_SAVEGAMES_AND_SYNCS_THEIR_C">Vuelve a escanear tus partidas guardadas y sincroniza su contenido con la base de datos de Tomb Launcher</system:String>
