    <system:String x:Key="DELETE_SAVEGAMES_MARKED_AS_START_OF_LEVEL">Supprimer les sauvegardes marquées comme début de niveau</system:String>
    <system:String x:Key="RESCANS_YOUR_BACKED_UP_SAVEGAMES_AND_SYNCS_THEIR_C">Analyse à nouveau vos sauvegardes et synchronise leur contenu avec la base de données de Tomb Launcher</system:String>
