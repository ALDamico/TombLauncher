    <system:String x:Key="PROTON_TOOLTIP_CONTENT">Proton is Valve's compatibility layer for running Windows games on Linux. Select an installation detected from your Steam library, or enter the path manually.</system:String>
    <system:String x:Key="PROTON_DATA_PATH">Proton data folder (optional)</system:String>
    <system:String x:Key="PROTON_DATA_PATH_TOOLTIP">A dedicated folder where Proton stores this game's settings and virtual Windows files (STEAM_COMPAT_DATA_PATH). Leave empty to use the global default.</system:String>
    <system:String x:Key="PROTON_VERSION">Proton version</system:String>
    <system:String x:Key="PROTON_NOT_FOUND">Proton not found</system:String>
    <system:String x:Key="PROTON_NOT_FOUND_DESCRIPTION">TombLauncher is set to use Proton, but no installation was found. Make sure you have Proton installed via Steam, or set the path manually in Settings → Compatibility.</system:String>
