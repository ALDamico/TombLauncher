    <system:String x:Key="WINE_PREFIX_PATH">Wine data folder (optional)</system:String>
    <system:String x:Key="WINE_PREFIX_TOOLTIP_CONTENT">A dedicated folder where Wine stores this game's settings and virtual Windows files, keeping them separate from other games. Leave empty to share the common default folder.</system:String>
