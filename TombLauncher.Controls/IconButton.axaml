<Button xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:controls="clr-namespace:TombLauncher.Controls"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="40"
             x:Class="TombLauncher.Controls.IconButton"
             Command="{Binding RelativeSource={RelativeSource Self}, Path=Command}"
             >
        <Button.Content>
            <StackPanel Orientation="Horizontal" Margin="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:IconButton}, Path=Margin}">
                <avalonia:MaterialIcon Kind="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:IconButton}, Path=Icon}" 
                                       Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:IconButton}, Path=FontSize}"
                                       Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:IconButton}, Path=FontSize}"/>
                <TextBlock Margin="4, 0, 0, 0"
                           VerticalAlignment="Center" 
                           Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:IconButton}, Path=Text}" 
                           FontSize="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:IconButton}, Path=FontSize}"
                           IsVisible="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=controls:IconButton}, Path=IsTextVisible}"/>
            </StackPanel>
        </Button.Content>
</Button>
